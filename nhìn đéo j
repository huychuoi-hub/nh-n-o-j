local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local LocalPlayer = Players.LocalPlayer
local PlayerGui = LocalPlayer:WaitForChild("PlayerGui")

local TARGET_NAME = "Generator"
local RANGE = 15
local lastCheck = 0

local function fastClick(button)
    if not button or not button.Visible then return end
    local events = {"MouseButton1Click", "MouseButton1Down", "Activated"}
    for _, event in ipairs(events) do
        if button[event] then
            for _, connection in pairs(getconnections(button[event])) do
                connection:Fire()
            end
        end
    end
end

local function solveTask(gui)
    for _, v in pairs(gui:GetDescendants()) do
        if v:IsA("GuiButton") and v.Visible then
            if v:IsA("ImageButton") or v:IsA("TextButton") then
                if v.BackgroundColor3.R > 0.5 or v.Name:lower():find("off") or v.Name:lower():find("wire") then
                    fastClick(v)
                end
            else
                fastClick(v)
            end
        end
    end
end

RunService.Heartbeat:Connect(function()
    if tick() - lastCheck < 0.1 then return end
    lastCheck = tick()

    local char = LocalPlayer.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    for _, obj in pairs(workspace:GetChildren()) do
        if obj.Name == TARGET_NAME then
            local pos = obj:IsA("Model") and obj:GetPivot().Position or (obj:IsA("BasePart") and obj.Position)
            if pos and (hrp.Position - pos).Magnitude <= RANGE then
                local p = obj:FindFirstChildOfClass("ProximityPrompt") or obj:FindFirstChild("Prompt", true)
                if p and fireproximityprompt then fireproximityprompt(p) end
            end
        end
    end

    for _, gui in pairs(PlayerGui:GetChildren()) do
        if gui:IsA("ScreenGui") and gui.Enabled then
            local n = gui.Name:lower()
            if n:find("gen") or n:find("repair") or n:find("task") or gui:FindFirstChild("MainFrame", true) then
                solveTask(gui)
            end
        end
    end
end)
