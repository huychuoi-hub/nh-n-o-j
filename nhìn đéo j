local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local LocalPlayer = Players.LocalPlayer
local PlayerGui = LocalPlayer:WaitForChild("PlayerGui")

local RANGE = 15
local TARGET_NAME = "Generator"
local solved = {}
local generatorCache = {}

-- Chức năng Anti-Lag: Thu thập danh sách máy phát điện 1 lần duy nhất
local function updateGeneratorCache()
    table.clear(generatorCache)
    for _, v in pairs(workspace:GetDescendants()) do
        if v:IsA("ProximityPrompt") and (v.Name:find(TARGET_NAME) or v.Parent.Name:find(TARGET_NAME)) then
            table.insert(generatorCache, v)
        end
    end
end
updateGeneratorCache()

-- Hàm click tối ưu
local function forceClick(v, holdTime)
    if not v or not v.Visible then return end
    task.spawn(function() -- Chạy trong thread riêng để không block loop chính
        pcall(function()
            v:Activate()
            if getconnections then
                for _, con in pairs(getconnections(v.MouseButton1Down)) do con:Fire() end
                if holdTime then task.wait(holdTime) end
                for _, con in pairs(getconnections(v.MouseButton1Up)) do con:Fire() end
            end
        end)
    end)
end

-- Logic giải đố (Giữ nguyên nhưng tối ưu vòng lặp)
local function solveTaskLogic(gui)
    local buttons = {}
    local images = {}

    for _, v in ipairs(gui:GetDescendants()) do -- Dùng ipairs cho bảng mảng
        if v:IsA("GuiButton") and v.Visible and v.AbsoluteSize.X > 0 then
            table.insert(buttons, v)
            local img = v:FindFirstChildOfClass("ImageLabel")
            if img and img.Image ~= "" then
                images[v] = img.Image
            end
        end
    end

    -- 1. Nối dây
    for btn, imgID in pairs(images) do
        if not solved[btn] then
            for otherBtn, otherImgID in pairs(images) do
                if btn ~= otherBtn and imgID == otherImgID and not solved[otherBtn] then
                    forceClick(btn)
                    task.wait(0.05)
                    forceClick(otherBtn)
                    solved[btn], solved[otherBtn] = true, true
                    return
                end
            end
        end
    end

    -- 2. Logic nút bấm (Màu sắc)
    local categories = {}
    for _, btn in ipairs(buttons) do
        if not solved[btn] and not images[btn] then
            local key = btn.BackgroundColor3:ToHex()
            categories[key] = categories[key] or {}
            table.insert(categories[key], btn)
        end
    end

    for _, list in pairs(categories) do
        if #list > 0 then -- Đơn giản hóa: Bấm loại đầu tiên tìm thấy
            for _, btn in ipairs(list) do
                forceClick(btn)
                solved[btn] = true
            end
            break
        end
    end
end

-- Vòng lặp chính tối ưu (Sử dụng task.wait dài hơn hoặc RunService)
task.spawn(function()
    while true do
        local hrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        
        if hrp then
            -- Tương tác bằng Cache thay vì quét toàn bộ Workspace
            for _, prompt in ipairs(generatorCache) do
                if prompt.Parent and (hrp.Position - prompt.Parent:GetPivot().Position).Magnitude <= RANGE then
                    if fireproximityprompt then 
                        fireproximityprompt(prompt) 
                    end
                end
            end

            -- Quét UI nhẹ nhàng hơn
            local currentGui = nil
            for _, gui in ipairs(PlayerGui:GetChildren()) do
                if gui:IsA("ScreenGui") and gui.Enabled and #gui:GetChildren() > 0 then
                    currentGui = gui
                    break
                end
            end

            if currentGui then
                solveTaskLogic(currentGui)
            else
                table.clear(solved) -- Clear table thay vì tạo table mới để tiết kiệm bộ nhớ
            end
        end
        
        task.wait(0.5) -- Tăng thời gian chờ lên một chút để CPU "thở"
    end
end)

-- Cập nhật cache mỗi 30 giây nếu map có thay đổi
task.spawn(function()
    while task.wait(30) do
        updateGeneratorCache()
    end
end)

print("--- [OPTIMIZED] Generator Auto Task Running ---")
