local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local LocalPlayer = Players.LocalPlayer
local PlayerGui = LocalPlayer:WaitForChild("PlayerGui")

local TARGET_NAME = "Generator"
local RANGE = 15
local cooldownUntil = 0
local solvedButtons = {}
local lastLeverTick = 0

local function fastClick(v)
    if not v or not v.Visible then return end
    pcall(function()
        for _, e in ipairs({"MouseButton1Down", "MouseButton1Click", "Activated", "MouseButton1Up"}) do
            if v[e] then for _, c in pairs(getconnections(v[e])) do c:Fire() end end
        end
    end)
end

local function solveTask(gui)
    local leftNodes = {}
    local rightNodes = {}
    local buttons = {}
    local levers = {}

    for _, v in pairs(gui:GetDescendants()) do
        if v:IsA("GuiButton") and v.Visible then
            local n = v.Name:lower()
            -- 1. Dây điện
            if n:find("wire") or n:find("node") then
                if not solvedButtons[v] then
                    if v.AbsolutePosition.X < (gui.AbsoluteSize.X / 2) then
                        table.insert(leftNodes, v)
                    else
                        table.insert(rightNodes, v)
                    end
                end
            -- 2. Nút bấm
            elseif n:find("button") or n:find("switch") then
                table.insert(buttons, v)
            -- 3. Cần gạt
            elseif n:find("lever") or n:find("handle") or n:find("pull") then
                table.insert(levers, v)
            end
        end
    end

    -- BƯỚC 1: NỐI DÂY
    local wireRemaining = false
    for _, l in ipairs(leftNodes) do
        for _, r in ipairs(rightNodes) do
            local colorL = l:IsA("ImageButton") and l.ImageColor3 or l.BackgroundColor3
            local colorR = r:IsA("ImageButton") and r.ImageColor3 or r.BackgroundColor3
            if colorL == colorR and not solvedButtons[l] then
                fastClick(l)
                task.wait(0.05)
                fastClick(r)
                solvedButtons[l], solvedButtons[r] = true, true
                wireRemaining = true
            end
        end
    end
    if #leftNodes > 0 and wireRemaining then return end

    -- BƯỚC 2: NHẤN NÚT (CHỈ BẤM 1 LẦN KHI ĐANG ĐEN)
    local buttonActive = false
    for _, b in ipairs(buttons) do
        if not solvedButtons[b] then
            local color = b:IsA("ImageButton") and b.ImageColor3 or b.BackgroundColor3
            if (color.R + color.G + color.B < 0.8) then
                fastClick(b)
                solvedButtons[b] = true
                buttonActive = true
            end
        end
    end
    if buttonActive then return end

    -- BƯỚC 3: CẦN GẠT (KÉO LÊN KÉO XUỐNG LIÊN TỤC)
    if tick() - lastLeverTick > 0.1 then -- Tốc độ lặp lại cần gạt
        lastLeverTick = tick()
        for _, lev in ipairs(levers) do
            pcall(function()
                -- Giả lập kéo xuống
                for _, c in pairs(getconnections(lev.MouseButton1Down)) do c:Fire() end
                task.wait(0.05)
                -- Giả lập kéo lên/thả ra
                for _, c in pairs(getconnections(lev.MouseButton1Up)) do c:Fire() end
            end)
        end
    end
end

RunService.Heartbeat:Connect(function()
    if tick() < cooldownUntil then return end

    local char = LocalPlayer.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    local isBusy = false
    for _, gui in pairs(PlayerGui:GetChildren()) do
        if gui:IsA("ScreenGui") and gui.Enabled then
            local n = gui.Name:lower()
            if n:find("gen") or n:find("repair") or n:find("task") or gui:FindFirstChild("MainFrame", true) then
                isBusy = true
                solveTask(gui)
            end
        end
    end

    if not isBusy then
        if next(solvedButtons) ~= nil then 
            solvedButtons = {} 
            cooldownUntil = tick() + 4 
        end
        for _, obj in pairs(workspace:GetChildren()) do
            if obj.Name == TARGET_NAME then
                local pos = obj:IsA("Model") and obj:GetPivot().Position or (obj:IsA("BasePart") and obj.Position)
                if pos and (hrp.Position - pos).Magnitude <= RANGE then
                    local p = obj:FindFirstChildOfClass("ProximityPrompt") or obj:FindFirstChild("Prompt", true)
                    if p and fireproximityprompt then fireproximityprompt(p) end
                end
            end
        end
    end
end)
