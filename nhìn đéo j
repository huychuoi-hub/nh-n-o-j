    if not hrp then return end

    -- Tự động tương tác với vật phẩm trong Map (ProximityPrompt)
    if tick() - lastInteractTick > 0.6 then -- Quét mỗi 0.6 giây
        for _, v in pairs(workspace:GetDescendants()) do
            if v:IsA("ProximityPrompt") then
                local parent = v.Parent
                local pos = parent:IsA("BasePart") and parent.Position or parent:GetPivot().Position
                if (hrp.Position - pos).Magnitude <= RANGE then
                    if fireproximityprompt then 
                        fireproximityprompt(v)
                        lastInteractTick = tick()
                    end
                end
            end
        end
    end

    -- Kiểm tra xem có UI task nào đang mở không
    local isDoingTask = false
    for _, gui in pairs(PlayerGui:GetChildren()) do
        -- Lọc bỏ các UI không phải là Task (Chat, v.v.)
        if gui:IsA("ScreenGui") and gui.Enabled and gui.Name ~= "Chat" and gui.Name ~= "BubbleChat" then
            -- Kiểm tra xem UI có chứa nút bấm nào không
            local hasButtons = false
            for _, child in pairs(gui:GetDescendants()) do
                if child:IsA("GuiButton") and child.Visible then
                    hasButtons = true
                    break
                end
            end

            if hasButtons then
                isDoingTask = true
                solveTask(gui)
                break
            end
        end
    end

    -- Reset bộ nhớ khi không còn UI nào mở
    if not isDoingTask and next(solvedButtons) ~= nil then
        solvedButtons = {}
        print("Task clean up.")
    end
end)
