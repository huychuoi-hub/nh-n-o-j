local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local LocalPlayer = Players.LocalPlayer
local PlayerGui = LocalPlayer:WaitForChild("PlayerGui")

-- === CẤU HÌNH ===
local RANGE = 15 -- Khoảng cách tự động kích hoạt task
local CLICK_DELAY = 0.15 -- Độ trễ giữa các lần bấm (tránh bị game kick/lag)
local solvedButtons = {}
local lastInteractTick = 0

print("--- [FULL] AUTO TASK LOADED ---")

-- === HÀM TRỢ GIÚP ===

-- Hàm click chuẩn cho hầu hết các Executor (Hỗ trợ getconnections)
local function universalClick(v)
    if not v or not v.Visible then return end
    pcall(function()
        local events = {"MouseButton1Click", "MouseButton1Down", "Activated"}
        for _, e in ipairs(events) do
            local cons = getconnections(v[e])
            if cons then
                for _, connection in pairs(cons) do
                    connection:Fire()
                end
            end
        end
    end)
end

-- So sánh màu sắc với sai số nhỏ (RGB delta)
local function isColorMatch(c1, c2)
    local delta = math.abs(c1.R - c2.R) + math.abs(c1.G - c2.G) + math.abs(c1.B - c2.B)
    return delta < 0.2 -- Ngưỡng khớp màu
end

-- === LOGIC GIẢI TASK ===

local function solveTask(gui)
    local leftNodes = {}
    local rightNodes = {}
    local genericButtons = {}
    local levers = {}

    -- 1. Phân loại Object trong UI
    for _, v in pairs(gui:GetDescendants()) do
        if v:IsA("GuiButton") and v.Visible and v.AbsoluteSize.X > 0 then
            local name = v.Name:lower()
            
            -- Nhận diện Wires (Dây điện)
            if name:find("wire") or name:find("node") or name:find("point") then
                if v.AbsolutePosition.X < (gui.AbsoluteSize.X / 2) then
                    table.insert(leftNodes, v)
                else
                    table.insert(rightNodes, v)
                end
            -- Nhận diện Cần gạt
            elseif name:find("lever") or name:find("handle") or name:find("switch") then
                table.insert(levers, v)
            -- Nhận diện Nút bấm chung
            else
                table.insert(genericButtons, v)
            end
        end
    end

    -- 2. Xử lý nối dây theo MÀU (Ưu tiên số 1)
    for _, l in ipairs(leftNodes) do
        if not solvedButtons[l] then
            local colorL = l:IsA("ImageButton") and l.ImageColor3 or l.BackgroundColor3
            for _, r in ipairs(rightNodes) do
                local colorR = r:IsA("ImageButton") and r.ImageColor3 or r.BackgroundColor3
                
                if isColorMatch(colorL, colorR) and not solvedButtons[r] then
                    universalClick(l)
                    task.wait(CLICK_DELAY)
                    universalClick(r)
                    solvedButtons[l], solvedButtons[r] = true, true
                    print("Connected wire: " .. tostring(colorL))
                    return -- Thoát để loop tiếp theo xử lý cặp mới
                end
            end
        end
    end

    -- 3. Xử lý nút bấm (Nếu là nút cần kích hoạt - màu tối/đỏ/v.v.)
    for _, b in ipairs(genericButtons) do
        if not solvedButtons[b] then
            local c = b:IsA("ImageButton") and b.ImageColor3 or b.BackgroundColor3
            -- Ví dụ: Click nếu nút màu tối (giả định là nút chưa bấm)
            if (c.R + c.G + c.B < 1.5) then 
                universalClick(b)
                solvedButtons[b] = true
                task.wait(CLICK_DELAY)
                return
            end
        end
    end

    -- 4. Xử lý cần gạt (Spam click/hold)
    for _, lev in ipairs(levers) do
        universalClick(lev)
    end
end

-- === VÒNG LẶP HỆ THỐNG ===

