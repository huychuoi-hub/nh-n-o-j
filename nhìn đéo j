local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local LocalPlayer = Players.LocalPlayer
local PlayerGui = LocalPlayer:WaitForChild("PlayerGui")

local TARGET_NAME = "Generator" 
local RANGE = 12 
local CHECK_INTERVAL = 0.1 

local hasNotified = false 
local currentGenUI = nil
local lastCheck = 0

-- Hàm kích hoạt mọi loại Prompt (kể cả loại tạo bằng script)
local function firePrompt(parent)
    for _, v in pairs(parent:GetDescendants()) do
        if v:IsA("ProximityPrompt") then
            if fireproximityprompt then
                fireproximityprompt(v)
            end
            return true
        end
    end
    return false
end

RunService.Heartbeat:Connect(function()
    if tick() - lastCheck < CHECK_INTERVAL then return end
    lastCheck = tick()

    local char = LocalPlayer.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    local nearGen = nil
    -- Quét diện rộng để tìm Generator
    for _, obj in pairs(workspace:GetDescendants()) do
        if obj.Name == TARGET_NAME and (obj:IsA("BasePart") or obj:IsA("Model")) then
            local pos = obj:IsA("Model") and obj:GetPivot().Position or obj.Position
            if (hrp.Position - pos).Magnitude <= RANGE then
                nearGen = obj
                break
            end
        end
    end

    if nearGen then
        if not hasNotified then
            -- Thông báo nếu có thư viện UI
            if _G.Window and _G.Window.Notify then
                _G.Window:Notify({Title = "Generator", Content = "Đang kết nối...", Duration = 2})
            end
            hasNotified = true
        end

        -- Ưu tiên 1: Kích hoạt ProximityPrompt
        local found = firePrompt(nearGen)

        -- Ưu tiên 2: Nếu không thấy Prompt, tự tìm và mở UI liên quan
        if not found and not currentGenUI then
            for _, gui in pairs(PlayerGui:GetChildren()) do
                if gui:IsA("ScreenGui") then
                    local n = gui.Name:lower()
                    if n:find("gen") or n:find("repair") or n:find("minigame") then
                        gui.Enabled = true
                        currentGenUI = gui
                    end
                end
            end
        end
    else
        hasNotified = false
        if currentGenUI then
            currentGenUI.Enabled = false
            currentGenUI = nil
        end
    end
end)
